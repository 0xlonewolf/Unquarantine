# Include full build outputs.
# We unignore the whole `bin/` and `obj/` trees, but explicitly ignore `bin/Debug/`.
bin/
!bin/
!bin/**
bin/Debug/
bin/Debug/**

obj/
!obj/
!obj/**

# publish outputs (self-contained single-file)
publish/
**/publish/

# But include published artifacts inside bin/Release
!bin/Release/**/publish/
!bin/Release/**/publish/**

# Note: we intentionally do include `bin/Release/**/publish/**` above.

# test artifacts / extracted content
*.out
*.met
*.recovered
*.name.txt
*.recovered.name.txt

# IDE/editor
.vs/
.vscode/
*.user
*.suo
*.swp

# OS
Thumbs.db
*.DS_Store

